## Visual Studio / .NET common ignores
# See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
out/
artifacts/

# Visual Studio Code
.vscode/

# Visual Studio
.vs/

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# DotCover
*.dotCover

# Resharper
_ReSharper*/
*.ReSharper*

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
/.vs/**/applicationhost.config
/.vs/**/IISExpress.config

# Publish directory
publish/
wwwroot/GeneratedFiles/

# Logs
*.log
TestResults/

# Coverage
coverage*
*.coverage
*.coveragexml

# Database files
*.mdf
*.ldf
*.db
*.sqlite

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
~$*
*.tmp
*.temp

# OneDrive / sync metadata
~*.tmp
*.lnk

# JetBrains local history
.idea/.idea.LocalHistory

# Avoid committing secrets or local settings
appsettings.Development.json
secrets.json
