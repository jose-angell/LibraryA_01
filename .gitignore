## Ignore Visual Studio temporary files, build outputs, and user-specific files

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio directories
.vs/
.vscode/

# Build results
[Bb]in/
[Oo]bj/
out/
artifacts/

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# Rider
.idea/
*.iml

# Resharper
_ReSharper*/
*.ReSharper*

# DotCover
*.dotCover

# SQL Server cache files
*.mdf
*.ldf

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
~$*
*.~* 
*.tmp

# Packages and publish outputs
publish/
pipelines/

# JetBrains Rider local history
.idea/.idea.LocalHistory

# Ignore JetBrains Rider caches
.idea/**/workspace.xml

# OneDrive cache/temp files
*.lnk
